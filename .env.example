# Copy to .env.local and fill in. Never commit .env.local.

# ---- App flags (Vercel runtime) -------------------------------------------
# When "true" the frontend renders src/data/demo-data.json instead of the
# live issue. Keep "false" in production.
NEXT_PUBLIC_DEMO_MODE=false

# Footer subscribe link (optional)
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/your_bot_handle

# ---- Daily issue pipeline (GitHub Actions secrets only — NOT for Vercel) --
# Used by scripts/daily-issue/ when run via `npm run generate:daily` or the
# `.github/workflows/daily-issue.yml` cron. Add these as repo secrets:
# Settings → Secrets and variables → Actions → New repository secret.
ANTHROPIC_API_KEY=sk-ant-api03-...
X_API_BEARER_TOKEN=AAAAAAAAAAAAAAAAAA...

# Optional: X consumer keys if you extend the pipeline to use user-context
# endpoints. Bearer token alone is enough for the current read-only fetcher.
X_API_CONSUMER_KEY=
X_API_CONSUMER_SECRET=
